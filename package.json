{
  "name": "eslint-plugin-no-barrel-files",
  "version": "1.3.1",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "clean": "node -e \"const fs = require('node:fs'); fs.rmSync('dist', { recursive: true, force: true }); fs.rmSync('tsconfig.build.tsbuildinfo', { force: true });\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "watch": "tsc -p tsconfig.build.json --watch",
    "test": "vitest",
    "test:coverage": "vitest --run --coverage",
    "lint": "eslint .",
    "lockfile:check": "git diff --exit-code -- package-lock.json",
    "pack:smoke": "npm run build && node ./scripts/smoke-pack.mjs",
    "consumer:smoke": "npm run build && node ./scripts/smoke-consumer.mjs",
    "release:dry-run": "semantic-release --dry-run",
    "semantic-release": "semantic-release"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "eslint",
    "plugin",
    "addon",
    "extension",
    "rule",
    "barrel",
    "import",
    "export"
  ],
  "author": "art0rz",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^10.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^10.0.5",
    "@semantic-release/release-notes-generator": "^11.0.4",
    "@typescript-eslint/parser": "^8.58.1",
    "@typescript-eslint/rule-tester": "^8.58.1",
    "@typescript-eslint/types": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.12.0",
    "semantic-release": "^21.1.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.58.1"
  },
  "peerDependencies": {
    "eslint": "^8.0.0 || ^9.0.0 || ^10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/art0rz/eslint-plugin-no-barrel-files.git"
  }
}
